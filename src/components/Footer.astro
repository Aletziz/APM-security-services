---
import { translations, PHONE_DISPLAY, PHONE_TEL, EMAIL } from '../i18n/translations.js';
import Logo from './Logo.astro';
const t = translations.en;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a class="brand" href="#top" aria-label="APM Security Services — home">
        <span class="brand__mark" aria-hidden="true">
          <Logo class="brand__logo" />
        </span>
        <span class="brand__text">
          <strong>APM</strong>
          <small>Security Services</small>
        </span>
      </a>
      <p class="footer__tag" data-i18n="footer.tagline">{t['footer.tagline']}</p>
    </div>

    <nav class="footer__col" aria-label="Services">
      <h3 data-i18n="footer.servicesTitle">{t['footer.servicesTitle']}</h3>
      <a href="#services" data-i18n="services.1.title">{t['services.1.title']}</a>
      <a href="#services" data-i18n="services.2.title">{t['services.2.title']}</a>
      <a href="#services" data-i18n="services.3.title">{t['services.3.title']}</a>
    </nav>

    <nav class="footer__col" aria-label="Coverage">
      <h3 data-i18n="footer.coverageTitle">{t['footer.coverageTitle']}</h3>
      <a href="#coverage" data-i18n="coverage.1.name">{t['coverage.1.name']}</a>
      <a href="#coverage" data-i18n="coverage.2.name">{t['coverage.2.name']}</a>
      <a href="#coverage" data-i18n="coverage.3.name">{t['coverage.3.name']}</a>
      <a href="#coverage" data-i18n="coverage.4.name">{t['coverage.4.name']}</a>
    </nav>

    <div class="footer__col">
      <h3 data-i18n="footer.contactTitle">{t['footer.contactTitle']}</h3>
      <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
      <span class="footer__muted" data-i18n="footer.license">{t['footer.license']}</span>
    </div>
  </div>

  <div class="container footer__bottom">
    <p>&copy; <span>{year}</span> APM Security Services. <span data-i18n="footer.rights">{t['footer.rights']}</span></p>
  </div>
</footer>

<style>
  .footer {
    background: #07101c;
    color: var(--white);
    padding-top: clamp(3rem, 2rem + 4vw, 5rem);
    border-top: 1px solid var(--line-dark);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .brand__mark {
    color: var(--accent);
    width: 32px;
    height: 34px;
    flex: none;
    display: block;
  }
  /* explicit height (not auto) so iOS Safari doesn't collapse the SVG to 0 */
  .brand__logo {
    width: 100%;
    height: 100%;
    display: block;
  }
  .brand__text strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .brand__text small {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--muted-dark);
    margin-top: 3px;
  }
  .footer__tag {
    margin-top: 1.1rem;
    color: var(--muted-dark);
    font-size: 0.9rem;
    max-width: 30ch;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer__col h3 {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }
  .footer__col a {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.92rem;
    transition: color 0.2s var(--ease);
  }
  .footer__col a:hover {
    color: var(--white);
  }
  .footer__muted {
    color: var(--muted-dark);
    font-size: 0.82rem;
    line-height: 1.5;
    margin-top: 0.2rem;
  }

  .footer__bottom {
    border-top: 1px solid var(--line-dark);
    padding-block: 1.5rem;
    color: var(--muted-dark);
    font-size: 0.82rem;
  }

  @media (max-width: 760px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  @media (max-width: 440px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
