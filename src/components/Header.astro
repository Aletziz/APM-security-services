---
import { translations, PHONE_TEL } from '../i18n/translations.js';
const t = translations.en;
---

<header class="site-header" id="site-header">
  <div class="container bar">
    <a class="brand" href="#top" aria-label="APM Security Services — home">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 24 28" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 1 22 5v8c0 6.5-4.3 11.3-10 14C6.3 24.3 2 19.5 2 13V5l10-4Z" />
        </svg>
      </span>
      <span class="brand__text">
        <strong>APM</strong>
        <small>Security Services</small>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="#services" data-i18n="nav.services">{t['nav.services']}</a>
      <a href="#coverage" data-i18n="nav.coverage">{t['nav.coverage']}</a>
      <a href="#why" data-i18n="nav.why">{t['nav.why']}</a>
      <a href="#contact" data-i18n="nav.contact">{t['nav.contact']}</a>
    </nav>

    <div class="actions">
      <div class="lang" role="group" aria-label={t['nav.langLabel']}>
        <button type="button" data-lang-btn="en">EN</button>
        <span aria-hidden="true">/</span>
        <button type="button" data-lang-btn="es">ES</button>
      </div>
      <a class="btn btn--accent call" href={`tel:${PHONE_TEL}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          ><path
            d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2Z"
          ></path></svg
        >
        <span data-i18n="nav.call">{t['nav.call']}</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease),
      box-shadow 0.35s var(--ease);
    border-bottom: 1px solid transparent;
  }

  /* Solid state once scrolled, toggled via JS class */
  .site-header.is-scrolled {
    background: rgba(10, 22, 38, 0.9);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--line-dark);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 76px;
    color: var(--white);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-right: auto;
  }
  .brand__mark {
    color: var(--accent);
    width: 26px;
  }
  .brand__text strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .brand__text small {
    display: block;
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--muted-dark);
    margin-top: 3px;
  }

  .nav {
    display: flex;
    gap: 1.9rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .nav a {
    position: relative;
    padding-block: 4px;
    color: rgba(255, 255, 255, 0.82);
    transition: color 0.2s var(--ease);
  }
  .nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }
  .nav a:hover {
    color: var(--white);
  }
  .nav a:hover::after {
    transform: scaleX(1);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted-dark);
  }
  .lang button {
    background: none;
    border: 0;
    color: var(--muted-dark);
    padding: 2px 1px;
    letter-spacing: 0.06em;
    transition: color 0.2s var(--ease);
  }
  .lang button.is-active {
    color: var(--accent);
  }
  .lang button:hover {
    color: var(--white);
  }

  @media (max-width: 860px) {
    .nav {
      display: none;
    }
    .bar {
      gap: 1rem;
    }
  }
  @media (max-width: 520px) {
    .call span {
      display: none;
    }
    .call {
      padding: 0.8rem;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () =>
      header.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
