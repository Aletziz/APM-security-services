---
import { translations } from '../i18n/translations.js';
const t = translations.en;

const items = [
  { key: '1', icon: `<path d="M12 2 4 5v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V5l-8-3Z"/><path d="m9 12 2 2 4-4"/>` },
  { key: '2', icon: `<circle cx="12" cy="8" r="4"/><path d="M5.5 21a7 7 0 0 1 13 0"/>` },
  { key: '3', icon: `<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"/>` },
  { key: '4', icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>` },
];
---

<section class="section section--paper" id="why">
  <div class="container">
    <div class="why">
      <div class="why__head reveal">
        <p class="eyebrow" data-i18n="why.eyebrow">{t['why.eyebrow']}</p>
        <h2 data-i18n="why.title">{t['why.title']}</h2>
      </div>

      <div class="why__grid">
        {
          items.map((it, i) => (
            <article class="feat reveal" style={`--d:${i * 0.08}s`}>
              <span class="feat__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" set:html={it.icon} />
              </span>
              <h3 data-i18n={`why.${it.key}.title`}>{t[`why.${it.key}.title`]}</h3>
              <p data-i18n={`why.${it.key}.desc`}>{t[`why.${it.key}.desc`]}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .why {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.6fr);
    gap: clamp(2rem, 1rem + 4vw, 5rem);
    align-items: start;
  }
  .why__head h2 {
    font-size: var(--step-3);
    margin-top: 1rem;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .feat {
    background: var(--white);
    padding: clamp(1.5rem, 1rem + 2vw, 2.25rem);
  }
  .feat__icon {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    color: var(--accent);
    border: 1px solid var(--line);
    margin-bottom: 1.1rem;
  }
  .feat__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .feat h3 {
    font-size: var(--step-1);
    margin-bottom: 0.55rem;
  }
  .feat p {
    color: var(--muted);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  @media (max-width: 880px) {
    .why {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .why__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
