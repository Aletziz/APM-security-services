---
import { Image } from 'astro:assets';
import { translations } from '../i18n/translations.js';
import imgGuard from '../assets/service-guard.png';
import imgPatrol from '../assets/service-patrol.png';
import imgCpo from '../assets/service-cpo.png';

const t = translations.en;

const services = [
  {
    n: '01',
    key: '1',
    img: imgGuard,
    alt: 'APM uniformed security guard at a corporate reception desk',
  },
  {
    n: '02',
    key: '2',
    img: imgPatrol,
    alt: 'APM Security Services marked patrol vehicle and officers at a commercial property',
  },
  {
    n: '03',
    key: '3',
    img: imgCpo,
    alt: 'APM Custom Protection Officers training at a tactical complex',
  },
];
---

<section class="section section--paper" id="services">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow" data-i18n="services.eyebrow">{t['services.eyebrow']}</p>
      <h2 data-i18n="services.title">{t['services.title']}</h2>
      <p data-i18n="services.lead">{t['services.lead']}</p>
    </div>

    <div class="svc-list">
      {
        services.map((s, i) => (
          <article class={`svc ${i % 2 === 1 ? 'svc--reverse' : ''}`}>
            <figure class="svc__media reveal">
              <Image
                src={s.img}
                alt={s.alt}
                class="svc__img"
                widths={[480, 768, 1120, 1440]}
                sizes="(max-width: 880px) 92vw, 46vw"
                loading="lazy"
              />
              <span class="svc__n" aria-hidden="true">
                {s.n}
              </span>
            </figure>

            <div class="svc__body reveal" style="--d:.12s">
              <h3 data-i18n={`services.${s.key}.title`}>{t[`services.${s.key}.title`]}</h3>
              <p class="svc__desc" data-i18n={`services.${s.key}.desc`}>
                {t[`services.${s.key}.desc`]}
              </p>
              <ul class="svc__list">
                <li data-i18n={`services.${s.key}.f1`}>{t[`services.${s.key}.f1`]}</li>
                <li data-i18n={`services.${s.key}.f2`}>{t[`services.${s.key}.f2`]}</li>
                <li data-i18n={`services.${s.key}.f3`}>{t[`services.${s.key}.f3`]}</li>
              </ul>
              <a class="svc__cta" href="#contact">
                <span data-i18n="services.cta">{t['services.cta']}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .svc-list {
    display: flex;
    flex-direction: column;
    gap: clamp(3.5rem, 2rem + 6vw, 7rem);
  }

  .svc {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.75rem, 1rem + 4vw, 4.5rem);
    align-items: center;
  }
  /* even rows: image on the right */
  .svc--reverse .svc__media {
    order: 2;
  }

  /* ---- media ---- */
  .svc__media {
    position: relative;
    margin: 0;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--ink);
  }
  .svc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    transition: transform 1.2s var(--ease);
  }
  /* settle-zoom as the image reveals into view */
  .svc__media.is-visible .svc__img {
    transform: scale(1);
  }
  .svc:hover .svc__media.is-visible .svc__img {
    transform: scale(1.04);
  }

  .svc__n {
    position: absolute;
    top: 0;
    left: 0;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--ink);
    background: var(--accent);
    padding: 0.55rem 0.9rem;
  }

  /* ---- body ---- */
  .svc__body h3 {
    font-size: var(--step-2);
    margin-bottom: 0.9rem;
  }
  .svc__body h3::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 3px;
    background: var(--accent);
    margin-bottom: 1.1rem;
  }
  .svc__desc {
    color: var(--muted);
    font-size: var(--step-0);
    line-height: 1.6;
  }
  .svc__list {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 1.6rem;
    display: grid;
    gap: 0.7rem;
  }
  .svc__list li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.95rem;
    color: var(--ink);
  }
  .svc__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.7rem;
    height: 2px;
    background: var(--accent);
  }

  .svc__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--accent);
  }
  .svc__cta svg {
    width: 1.1em;
    height: 1.1em;
    color: var(--accent);
    transition: transform 0.3s var(--ease);
  }
  .svc__cta:hover svg {
    transform: translateX(5px);
  }

  @media (max-width: 880px) {
    .svc {
      grid-template-columns: 1fr;
    }
    /* always stack the image on top, regardless of row parity */
    .svc--reverse .svc__media {
      order: 0;
    }
  }
</style>
