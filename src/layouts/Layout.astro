---
// Variable fonts (weight axis only). Browsers fetch just the Latin subset at
// runtime via unicode-range, so on-disk size ≠ transferred size.
import '@fontsource-variable/space-grotesk/wght.css';
import '@fontsource-variable/inter/wght.css';
import '../styles/global.css';
import { translations, PHONE_TEL, EMAIL } from '../i18n/translations.js';

const t = translations.en;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('og-image.jpg', Astro.site).href;

const keywords = [
  // Generic service + location (what people search when they don't know the name)
  'security service West Palm Beach',
  'security services West Palm Beach',
  'security guard service West Palm Beach',
  'security company West Palm Beach',
  'security companies West Palm Beach',
  'security guards West Palm Beach',
  'private security West Palm Beach',
  'security guard near me',
  'security service near me',
  'security companies near me',
  // Other cities served
  'security service Broward',
  'security service Miami',
  'security service Orlando',
  'security services Palm Beach County',
  // Service-type
  'armed and unarmed security',
  'vehicle patrol security',
  'custom protection officers',
  'executive protection Florida',
  'event security Florida',
  '24/7 security services',
  'licensed security guards',
  // Brand
  'APM Security Services',
].join(', ');

const cities = ['West Palm Beach', 'Broward County', 'Miami', 'Orlando'];

const offerings = [
  { name: 'Security Guard', desc: t['services.1.desc'] },
  { name: 'Vehicle Patrol', desc: t['services.2.desc'] },
  { name: 'Custom Protection Officers', desc: t['services.3.desc'] },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SecurityService',
  '@id': `${Astro.site}#business`,
  name: 'APM Security Services',
  alternateName: 'APM Security',
  url: Astro.site?.href,
  image: ogImage,
  logo: new URL('icon-512.png', Astro.site).href,
  telephone: PHONE_TEL,
  email: EMAIL,
  description: t['meta.description'],
  priceRange: '$$',
  currenciesAccepted: 'USD',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'FL',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 26.7153, longitude: -80.0534 },
  areaServed: cities.map((c) => ({ '@type': 'City', name: c, containedInPlace: 'Florida, US' })),
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
  makesOffer: offerings.map((o) => ({
    '@type': 'Offer',
    itemOffered: { '@type': 'Service', name: o.name, description: o.desc },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title data-i18n="meta.title">{t['meta.title']}</title>
    <meta name="description" data-i18n-content="meta.description" content={t['meta.description']} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="APM Security Services" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonical} />

    <!-- Favicon / icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-96.png" sizes="96x96" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a1626" />

    <!-- Local SEO (geo) -->
    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="West Palm Beach, Broward, Miami, Orlando" />
    <meta name="geo.position" content="26.7153;-80.0534" />
    <meta name="ICBM" content="26.7153, -80.0534" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="APM Security Services" />
    <meta property="og:title" content={t['meta.title']} />
    <meta property="og:description" content={t['meta.description']} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="APM Security Services — licensed security across Florida" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t['meta.title']} />
    <meta name="twitter:description" content={t['meta.description']} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a href="#main" class="skip-link" data-i18n="nav.skip">Skip to content</a>
    <slot />
  </body>
</html>

<script>
  // ---- Reveal on scroll ----
  const items = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window && items.length) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    items.forEach((el) => io.observe(el));
  } else {
    items.forEach((el) => el.classList.add('is-visible'));
  }
</script>

<script>
  // ---- Language toggle (EN default, swap to ES) ----
  import { translations } from '../i18n/translations.js';

  const STORE_KEY = 'apm-lang';

  function applyLang(lang) {
    const dict = translations[lang] || translations.en;
    document.documentElement.lang = lang;

    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key] != null) el.textContent = dict[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key && dict[key] != null) el.setAttribute('placeholder', dict[key]);
    });
    document.querySelectorAll('[data-i18n-content]').forEach((el) => {
      const key = el.getAttribute('data-i18n-content');
      if (key && dict[key] != null) el.setAttribute('content', dict[key]);
    });
    document.querySelectorAll('[data-i18n-aria]').forEach((el) => {
      const key = el.getAttribute('data-i18n-aria');
      if (key && dict[key] != null) el.setAttribute('aria-label', dict[key]);
    });

    document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
      const active = btn.getAttribute('data-lang-btn') === lang;
      btn.setAttribute('aria-pressed', String(active));
      btn.classList.toggle('is-active', active);
    });
    try {
      localStorage.setItem(STORE_KEY, lang);
    } catch (e) {}
  }

  // expose for the form's WhatsApp builder
  window.__apmLang = () => {
    try {
      return localStorage.getItem(STORE_KEY) || 'en';
    } catch (e) {
      return 'en';
    }
  };

  let initial = 'en';
  try {
    initial = localStorage.getItem(STORE_KEY) || 'en';
  } catch (e) {}
  if (initial !== 'en') applyLang(initial);
  else {
    document.querySelectorAll('[data-lang-btn="en"]').forEach((b) => {
      b.setAttribute('aria-pressed', 'true');
      b.classList.add('is-active');
    });
  }

  document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
    btn.addEventListener('click', () => applyLang(btn.getAttribute('data-lang-btn')));
  });
</script>
